generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FeedType {
  RSS_NEWS
  PODCAST
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Station {
  id          String       @id @default(uuid()) @db.Uuid
  slug        String       @unique
  name        String
  tenantId    String       @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  feeds       Feed[]
  mediaAssets MediaAsset[]
  podcasts    Podcast[]
  newsItems   NewsItem[]
}

model Feed {
  id               String          @id @default(uuid()) @db.Uuid
  stationId        String          @db.Uuid
  externalSourceId String?         @db.Uuid
  name             String
  url              String
  type             FeedType
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  station          Station         @relation(fields: [stationId], references: [id])
  externalSource   ExternalSource? @relation(fields: [externalSourceId], references: [id])
  ingestJobs       IngestJob[]

  @@index([stationId, type])
}

model ExternalSource {
  id          String   @id @default(uuid()) @db.Uuid
  provider    String
  sourceType  String
  credentials Json?
  stationId   String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  feeds       Feed[]
}

model IngestJob {
  id         String    @id @default(uuid()) @db.Uuid
  feedId     String?   @db.Uuid
  type       String
  status     JobStatus @default(PENDING)
  payload    Json?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  feed       Feed?     @relation(fields: [feedId], references: [id])
}

model MediaAsset {
  id          String   @id @default(uuid()) @db.Uuid
  stationId   String   @db.Uuid
  sourceUrl   String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  station     Station  @relation(fields: [stationId], references: [id])
}

model Podcast {
  id          String           @id @default(uuid()) @db.Uuid
  stationId   String           @db.Uuid
  title       String
  description String?
  feedUrl     String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  station     Station          @relation(fields: [stationId], references: [id])
  episodes    PodcastEpisode[]
}

model PodcastEpisode {
  id          String    @id @default(uuid()) @db.Uuid
  podcastId   String    @db.Uuid
  guid        String    @unique
  title       String
  publishedAt DateTime?
  audioUrl    String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  podcast     Podcast   @relation(fields: [podcastId], references: [id])
}

model NewsItem {
  id          String    @id @default(uuid()) @db.Uuid
  stationId   String    @db.Uuid
  externalId  String?
  title       String
  body        String?
  sourceUrl   String?
  publishedAt DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  station     Station   @relation(fields: [stationId], references: [id])
}

model SyncJob {
  id           String    @id @default(uuid()) @db.Uuid
  stationId    String?   @db.Uuid
  targetSystem String
  status       JobStatus @default(PENDING)
  payload      Json?
  response     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AiJob {
  id        String    @id @default(uuid()) @db.Uuid
  stationId String?   @db.Uuid
  pipeline  String
  status    JobStatus @default(PENDING)
  input     Json
  output    Json?
  provider  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
